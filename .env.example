# ============================================
# Frontend Environment Variables (React)
# ============================================

# Contact info (optional, has defaults)
REACT_APP_PHONE=909-615-6633
REACT_APP_EMAIL=familyfriendshibachi@gmail.com
REACT_APP_BASE_URL=https://familyfriendshibachi.com

# Pricing (optional, has defaults)
REACT_APP_PRICE_PER_PERSON=60
REACT_APP_MINIMUM_ORDER=600
REACT_APP_KIDS_PRICE=30

# Business hours (optional, has defaults)
REACT_APP_HOURS_AFTERNOON=1:00 PM - 3:00 PM
REACT_APP_HOURS_EVENING=4:00 PM - 6:00 PM
REACT_APP_HOURS_NIGHT=7:00 PM - 9:00 PM

# Feature flags
REACT_APP_ENABLE_ADMIN=true

# ============================================
# Backend Environment Variables (Cloudflare)
# Set these in the Cloudflare Dashboard under
# Pages > Settings > Environment Variables
# ============================================

# Required: Resend API key for email sending
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Required: Email address that receives booking notifications
# NOTIFICATION_EMAIL=your-admin@email.com

# Required: Admin dashboard login password (use a strong password!)
# ADMIN_PASSWORD=your-strong-password-here

# Required: Secret for cron job authentication
# CRON_SECRET=your-random-cron-secret

# Required: Restrict CORS to your domain(s), comma-separated
# ALLOWED_ORIGINS=https://familyfriendshibachi.com

# ============================================
# Cloudflare Bindings (set via dashboard)
# ============================================

# KV Namespace: family-friends-hibachi-bookings -> binding: BOOKINGS
# R2 Bucket: family-friends-hibachi-photos -> binding: PHOTOS
